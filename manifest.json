{
  "manifest_version": 3,
  "name": "591 租屋列表過濾",
  "version": "1.3",
  "description": "在 591 租屋列表頁面注入移除按鈕，隱藏指定物件並持久化儲存 (第二階段)",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://rent.591.com.tw/list*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}