{
  "manifest_version": 3,
  "name": "591 租屋列表過濾",
  "version": "1.4",
  "description": "在 591 租屋列表頁面注入移除按鈕，隱藏指定物件並持久化儲存，提供物件管理介面",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://rent.591.com.tw/list*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "591 租屋列表過濾"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}